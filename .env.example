# OpenID Connect (OIDC) credentials for the login wall.

# Base issuer URL of your OIDC server, WITHOUT the
# `/.well-known/openid-configuration` suffix (Reflex appends that itself).
#
# e.g. if your well-known URL is
#     https://sso.example.com/.well-known/openid-configuration
# then set:
#     OIDC_ISSUER_URI=https://sso.example.com
OIDC_ISSUER_URI=

# Client credentials issued when you registered this app with the OIDC server.
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
